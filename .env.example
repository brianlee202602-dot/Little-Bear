# Little Bear P0 本地启动配置
#
# 这里仅允许保存 PostgreSQL 连接和 API 进程启动参数。
# Redis、MinIO、Qdrant、模型网关、安全、检索、缓存、限流和审计等业务配置，
# 必须在初始化流程中写入数据库，并由 active_config v1 驱动 ServiceBootstrap。

APP_ENV=local
SERVICE_NAME=api
LOG_LEVEL=INFO

# PostgreSQL 本地容器初始化和宿主机进程连接配置。
POSTGRES_DB=little_bear
POSTGRES_USER=little_bear
POSTGRES_PASSWORD=little_bear_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://little_bear:little_bear_dev@localhost:5432/little_bear
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_POOL_SIZE=5
DATABASE_POOL_MAX_OVERFLOW=10
DATABASE_SSL_MODE=

# API 本地开发进程配置。
API_HOST=0.0.0.0
API_PORT=8000
