# Little Bear P0 数据库启动配置
#
# 这里仅允许保存 PostgreSQL 初始化和数据库连接参数。
# Redis、MinIO、Qdrant、模型 provider、安全、检索、缓存、限流和审计等业务配置，
# 必须在初始化流程中写入数据库，并由 active_config v1 驱动 ServiceBootstrap。

# Qdrant / embedding provider 真实联调测试配置。
LITTLE_BEAR_QDRANT_URL=http://localhost:6333
LITTLE_BEAR_EMBEDDING_URL=http://localhost:8081
LITTLE_BEAR_EMBEDDING_PROVIDER_TYPE=tei
LITTLE_BEAR_EMBEDDING_MODEL=jina-embeddings-v2-base-zh
LITTLE_BEAR_EMBEDDING_DIMENSION=768
LITTLE_BEAR_INTEGRATION_TIMEOUT_SECONDS=30

APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL 本地容器初始化和宿主机进程连接配置。
POSTGRES_DB=little_bear
POSTGRES_USER=little_bear
POSTGRES_PASSWORD=little_bear_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://little_bear:little_bear_dev@localhost:5432/little_bear
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_POOL_SIZE=5
DATABASE_POOL_MAX_OVERFLOW=10
DATABASE_SSL_MODE=

# API 本地开发进程配置。
API_HOST=0.0.0.0
API_PORT=8000
ADMIN_SETUP_URL=http://localhost:5174/admin/setup-initialization
SETUP_TOKEN_LOG_ENABLED=true
# 本地未设置时会使用进程内临时密钥；生产环境应显式设置并妥善保管。
SETUP_TOKEN_SIGNING_SECRET=
# 用于加密 PostgreSQL secrets 表中的密钥值。请使用强随机值，生产环境不得丢失或提交到代码库。
# 示例生成：openssl rand -base64 64
SECRET_STORE_MASTER_KEY=

# 以下变量只用于初始化写入 PostgreSQL secrets 表。
# 执行 app.cli.secrets put --value-env 写入成功后，请从 .env 中删除这些明文值。
# MinIO 两项必须与 docker-compose.yml 中的 MINIO_ROOT_USER / MINIO_ROOT_PASSWORD 保持一致。
SECRET_INIT_MINIO_ACCESS_KEY=minioadmin
SECRET_INIT_MINIO_SECRET_KEY=minioadmin
# Qdrant 未开启 API Key 鉴权时保持为空；开启后可写入 secret://rag/qdrant/api-key。
SECRET_INIT_QDRANT_API_KEY=
# 示例生成：openssl rand -base64 64
SECRET_INIT_JWT_SIGNING_KEY=
