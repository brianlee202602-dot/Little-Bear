# Little Bear P0 local development environment
#
# Process startup configuration is intentionally limited to database connection
# and process/runtime parameters. Redis, MinIO, Qdrant, model gateway, security,
# retrieval and audit settings must be written through setup-initialization as
# active_config v1.

COMPOSE_PROJECT_NAME=little-bear

POSTGRES_DB=little_bear
POSTGRES_USER=little_bear
POSTGRES_PASSWORD=little_bear_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://little_bear:little_bear_dev@postgres:5432/little_bear

API_HOST=0.0.0.0
API_PORT=8000
WORKER_CONCURRENCY=1
LOG_LEVEL=INFO

REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=little-bear-rag
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MODEL_GATEWAY_PORT=8080

